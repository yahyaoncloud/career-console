# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="your-gemini-api-key-here"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE & ENCRYPTION
MONGO_URI="mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/portfolio?retryWrites=true&w=majority"
ENCRYPTION_KEY="f83a45b9102c9a87d6e543b2f10d98c7e65f43a21b09d8c7e65f43a21b09d8c7"
JWT_SECRET="a0b1c2d3e4f567890123456789abcdef0123456789abcdef0123456789abcdef"

# AUTOMATION & SCRAPING
TELEGRAM_BOT_TOKEN="1234567890:ABCdefGhIJKlmNoPQRsTUVwxyZ123456789"
TELEGRAM_CHAT_ID="-1001234567890"

# GITHUB ACTIONS DISPATCH (required for Telegram /scrape command on Vercel Hobby)
# Create a PAT at https://github.com/settings/tokens with repo + workflow scopes
GH_PAT="ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Your GitHub username
GITHUB_OWNER="your-github-username"
# The repo name (without owner prefix)
GITHUB_REPO="job-application-tracker-portfolio"

# Firebase Client SDK — VITE_ prefix exposes these to the Vite browser bundle.
# Get from Firebase Console → Project Settings → Your Apps → Web App → SDK setup.
# Public config values (NOT secrets). Security enforced by Firebase Security Rules.
VITE_FIREBASE_API_KEY="AIzaSy..."
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="123456789"
VITE_FIREBASE_APP_ID="1:123456789:web:abc123"
